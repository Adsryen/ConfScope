{
  "name": "confscope",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "description": "ConfScope - 统一配置中心管理工具：浏览、对比、洞察多配置中心（Nacos/Apollo/Consul 等）的配置差异。",
  "scripts": {
    "dev": "wails dev",
    "dev:web": "vite",
    "build": "wails build",
    "dist": "wails build",
    "build:win": "wails build -clean -nsis",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "wails": "wails"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react": "^18",
    "react-dom": "^18",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "esbuild": "^0.28.0",
    "typescript": "^5",
    "vite": "^5"
  }
}
